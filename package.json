{
  "name": "@navable/mcp",
  "version": "0.3.0",
  "description": "Free, real-browser accessibility scanner for AI coding agents. Scans localhost with Playwright + axe-core (and optionally Pa11y/HTMLCS), returns WCAG 2.1 Level A + AA violations with fix plans.",
  "type": "module",
  "bin": {
    "navable-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "npm run build && node test/smoke/smoke-test.mjs",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "accessibility",
    "a11y",
    "wcag",
    "bfsg",
    "axe-core",
    "playwright",
    "cursor",
    "claude",
    "ai",
    "ide"
  ],
  "author": "navable",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/web-DnA/navable-web-accessibility-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/web-DnA/navable-web-accessibility-mcp/issues"
  },
  "homepage": "https://navable.io/",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "@axe-core/playwright": "4.11.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "pa11y": "^9.1.1",
    "playwright": "1.61.0",
    "puppeteer-core": "25.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.0.0",
    "@types/pa11y": "^5.3.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
